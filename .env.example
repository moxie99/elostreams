# PostgreSQL connection string used by the waitlist API + admin dashboard.
# In Railway: open your Postgres service -> "Connect" -> copy the connection URL.
DATABASE_URL="postgresql://user:password@host:5432/railway"

# Secret used to sign admin session cookies. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET="replace-with-a-long-random-string"

# Create your admin login with:
#   npm run create-admin -- you@example.com "your-password"
